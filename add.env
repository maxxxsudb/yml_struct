env:
  - name: AIRFLOW__METRICS__OTEL_ON
    value: "True"
  - name: AIRFLOW__METRICS__OTEL_HOST
    value: "alloy.monitoring.svc.cluster.local" # Внутренний k8s DNS адрес Alloy
  - name: AIRFLOW__METRICS__OTEL_PORT
    value: "4318"

AIRFLOW__METRICS__OTEL_INTERVAL_MILLISECONDS=30000
AIRFLOW__METRICS__STATSD_ON=False


otelcol.receiver.otlp "airflow" {
  http {
    endpoint = "0.0.0.0:4318"
  }
  output {
    metrics = [otelcol.exporter.prometheus.airflow_metrics.input]
  }
}

otelcol.exporter.prometheus "airflow_metrics" {
  // Важно: имя default.receiver должно совпадать с твоим реальным блоком отправки в базу!
  forward_to = [prometheus.remote_write.default.receiver] 
}
