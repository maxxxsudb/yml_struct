  "panels": [
    {
      "title": "System Health",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0.1 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "options": { "textMode": "value" },
      "targets": [
        {
          "expr": "rate(airflow_scheduler_heartbeat_total[$__rate_interval])",
          "refId": "A"
        }
      ],
      "title": "Scheduler Heartbeat",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "targets": [
        {
          "expr": "sum by (dag_id) (rate(airflow_dagrun_duration_success_sum{dag_id=~\"$dag_id\"}[$__rate_interval])) / sum by (dag_id) (rate(airflow_dagrun_duration_success_count{dag_id=~\"$dag_id\"}[$__rate_interval]))",
          "legendFormat": "{{dag_id}}",
          "refId": "A"
        }
      ],
      "title": "Average DAG Run Duration (Success)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "targets": [
        {
          "expr": "sum by (dag_id, task_id) (increase(airflow_ti_failures_total{dag_id=~\"$dag_id\", task_id=~\"$task_id\"}[$__rate_interval]))",
          "legendFormat": "{{dag_id}} - {{task_id}}",
          "refId": "A"
        }
      ],
      "title": "Task Failures (Increase)",
      "type": "timeseries"
    }
  ],
  "refresh": "1m",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["airflow", "otlp", "otel"],
