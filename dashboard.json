        "orientation": "horizontal",
        "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false },
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "expr": "nifi_jvm_uptime{instance=\"$instance\",cluster=\"$cluster\"}",
          "format": "time_series",
          "instant": true,
          "refId": "A",
          "step": 60
        }
