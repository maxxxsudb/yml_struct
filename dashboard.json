      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "decimals": 1,
          "mappings": [ { "options": { "match": "null", "result": { "text": "N/A" } }, "type": "special" } ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 80 } ] },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 1 },
      "id": 45,
      "options": {
        "colorMode": "value",
