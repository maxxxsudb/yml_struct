---
apiVersion: v1
kind: Pod
metadata:
  name: plugin-uploader
  labels:
    app: plugin-uploader # Лейбл для селектора сервиса
spec:
  containers:
  - name: filebrowser
    image: filebrowser/filebrowser:latest
    ports:
    - containerPort: 80
    volumeMounts:
    - name: plugins-volume
      mountPath: /srv # Директория, которую отдает filebrowser
  volumes:
  - name: plugins-volume
    persistentVolumeClaim:
      claimName: jmeter-plugins-pvc # Убедитесь, что имя совпадает с вашим PVC

---
apiVersion: v1
kind: Service
metadata:
  name: plugin-uploader-svc
spec:
  selector:
    app: plugin-uploader
  ports:
    - protocol: TCP
      port: 80
      targetPort: 80
