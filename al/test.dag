from airflow import DAG
from airflow.operators.bash import BashOperator
from datetime import datetime

with DAG('test_s3_logging', start_date=datetime(2023, 1, 1), schedule_interval=None) as dag:
    t1 = BashOperator(
        task_id='print_hello',
        bash_command='echo "Hello S3 Logging!" && sleep 5'
    )
