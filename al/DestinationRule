apiVersion: networking.istio.io/v1beta1
kind: DestinationRule
metadata:
  name: nifi
  namespace: your-namespace
spec:
  host: nifi.your-namespace.svc.cluster.local  # FQDN сервиса
  trafficPolicy:
    connectionPool:
      tcp:
        maxConnections: 100
        connectTimeout: 30s
        tcpKeepalive:
          time: 7200s        # 2 часа
          interval: 75s
          probes: 9
      http:
        http1MaxPendingRequests: 1024
        http2MaxRequests: 1024
        maxRequestsPerConnection: 0     # Без лимита - важно!
        maxRetries: 0
        idleTimeout: 7200s              # 2 часа - КРИТИЧНО
        h2UpgradePolicy: UPGRADE        # Для WebSocket
