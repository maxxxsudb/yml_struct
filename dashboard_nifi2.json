          "targets": [ { "expr": "nifi_jvm_gc_runs{instance=\"$instance\",cluster=\"$cluster\"}", "format": "time_series", "legendFormat": " {{gc_name}}", "refId": "A" } ],
          "title": "JVM GC Runs",
