          "gridPos": { "h": 7, "w": 12, "x": 12, "y": 27 },
          "id": 43,
          "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi" } },
          "targets": [ { "expr": "nifi_jvm_thread_count{instance=\"$instance\",cluster=\"$cluster\"}", "format": "time_series", "legendFormat": " ", "refId": "A" } ],
