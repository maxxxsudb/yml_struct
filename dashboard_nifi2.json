        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
          "gridPos": { "h": 7, "w": 12, "x": 0, "y": 27 },
          "id": 47,
          "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi" } },
          "targets": [ { "expr": "nifi_jvm_file_descriptor_usage{instance=\"$instance\",cluster=\"$cluster\"}", "format": "time_series", "legendFormat": " ", "refId": "A" } ],
