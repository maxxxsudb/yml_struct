          "targets": [ { "expr": "nifi_jvm_daemon_thread_count{instance=\"$instance\",cluster=\"$cluster\"}", "format": "time_series", "legendFormat": " ", "refId": "A" } ],
          "title": "JVM Daemon Thread Count",
