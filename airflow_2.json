{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "datasource", "uid": "grafana" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "panels": [
    {
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Глобальное здоровье кластера (System Health)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0.1 }
            ]
          },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 1 },
      "id": 2,
      "options": { "textMode": "value" },
      "targets": [
        { "expr": "rate(airflow_scheduler_heartbeat_total[$__rate_interval])", "refId": "A" }
      ],
      "title": "Пульс планировщика (Scheduler Heartbeat)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 1 },
      "id": 3,
      "options": { "displayMode": "lcd", "orientation": "horizontal" },
      "targets": [
        { "expr": "sum by (pool_name) (airflow_pool_open_slots)", "legendFormat": "Open: {{pool_name}}", "refId": "A" },
        { "expr": "sum by (pool_name) (airflow_pool_running_slots)", "legendFormat": "Running: {{pool_name}}", "refId": "B" }
      ],
      "title": "Пул соединений с БД (Database Connection Pool)",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 1 },
      "id": 4,
      "targets": [
        { "expr": "rate(airflow_triggerer_heartbeat_total[$__rate_interval])", "refId": "A" }
      ],
      "title": "Пульс триггеров (Triggerer Heartbeat)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 6 },
      "id": 5,
      "targets": [
        {
          "expr": "sum(rate(airflow_dag_processing_last_duration_sum[$__rate_interval])) / sum(rate(airflow_dag_processing_last_duration_count[$__rate_interval]))",
          "legendFormat": "Avg Parsing Time",
          "refId": "A"
        }
      ],
      "title": "Время парсинга DAG-файлов (DAG Processing Time)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["airflow", "otel", "system"],
  "templating": {
    "list": [
      {
        "datasource": { "type": "prometheus" },
        "definition": "label_values(airflow_pool_open_slots, pool_name)",
        "name": "pool",
        "query": "label_values(airflow_pool_open_slots, pool_name)",
        "refresh": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Airflow 2.10.4 - System Health (OTLP)",
  "uid": "airflow-system-otlp"
}
